            {
              "id": "2d3e14d5-ffd1-3b0c-a634-da45766876f4",
              "shortDescription": {
                "text": "Vulnerability: CVE-2024-21507\\nComponent: CVE-2024-21507/pkg:npm/mysql2@1.7.0"
